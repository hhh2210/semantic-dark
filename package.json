{
  "name": "semantic-dark",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hhh2210/semantic-dark.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "benchmark:feature-router": "tsx scripts/feature-router.ts",
    "benchmark:paired-theme": "tsx scripts/paired-theme.ts",
    "benchmark:paired-theme-heldout": "tsx scripts/paired-theme-heldout.ts",
    "benchmark:vision": "tsx scripts/benchmark-vision.ts",
    "build": "node scripts/build.mjs",
    "e2e": "pnpm build && node scripts/e2e.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@adobe/design-data-spec": "2.8.0",
    "@adobe/spectrum-design-data": "0.12.0",
    "@carbon/themes": "11.77.0",
    "@fluentui/react-theme": "9.2.1",
    "@material/material-color-utilities": "0.4.0",
    "@primer/primitives": "11.9.0",
    "@types/chrome": "0.2.2",
    "@types/node": "26.1.1",
    "@types/pngjs": "6.0.5",
    "esbuild": "0.28.1",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "pngjs": "7.0.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
