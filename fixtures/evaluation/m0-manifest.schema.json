{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hhh2210/semantic-dark/fixtures/evaluation/m0-manifest.schema.json",
  "title": "Semantic Dark M0 manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "baseline",
    "role_profiles",
    "mechanism_fixtures",
    "harm_contract",
    "real_page_pilot"
  ],
  "properties": {
    "schema": {"const": "semantic-dark.m0-manifest.v1"},
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "recorded_at", "verify", "e2e"],
      "properties": {
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "recorded_at": {"type": "string", "format": "date-time"},
        "verify": {"$ref": "#/$defs/commandResult"},
        "e2e": {
          "allOf": [{"$ref": "#/$defs/commandResult"}],
          "type": "object",
          "required": ["chrome_version", "metrics", "invariants"],
          "properties": {
            "chrome_version": {"type": "string"},
            "metrics": {"type": "object"},
            "invariants": {"type": "object"}
          }
        }
      }
    },
    "role_profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "source_sha256", "canonical_sha256", "values"],
      "properties": {
        "source": {"type": "string"},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "canonical_sha256": {"$ref": "#/$defs/sha256"},
        "values": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/roleProfile"}
        }
      }
    },
    "mechanism_fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/mechanismFixture"}
    },
    "harm_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frozen_before_m1", "hard_failures", "severity_levels"],
      "properties": {
        "frozen_before_m1": {"const": true},
        "hard_failures": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/harmRule"}
        },
        "severity_levels": {
          "type": "array",
          "minItems": 3,
          "items": {"$ref": "#/$defs/severityLevel"}
        }
      }
    },
    "real_page_pilot": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {"$ref": "#/$defs/pilotCase"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "commandResult": {
      "type": "object",
      "required": ["command", "exit_code", "status"],
      "properties": {
        "command": {"type": "string"},
        "exit_code": {"const": 0},
        "status": {"const": "passed"}
      }
    },
    "roleProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumLightness", "lightnessSpan", "chromaScale"],
      "properties": {
        "minimumLightness": {"type": "number"},
        "lightnessSpan": {"type": "number"},
        "chromaScale": {"type": "number"}
      }
    },
    "filePin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "mechanismFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "origin", "purpose", "files", "assertions"],
      "properties": {
        "id": {"type": "string"},
        "origin": {"const": "self-authored-reduction"},
        "purpose": {"type": "string"},
        "files": {"type": "array", "items": {"$ref": "#/$defs/filePin"}},
        "assertions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "harmRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "condition", "measurement"],
      "properties": {
        "id": {"type": "string"},
        "condition": {"type": "string"},
        "measurement": {"type": "string"}
      }
    },
    "severityLevel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "definition", "gate"],
      "properties": {
        "level": {"enum": ["H3", "H2", "H1", "H0"]},
        "definition": {"type": "string"},
        "gate": {"type": "string"}
      }
    },
    "pilotCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "url",
        "category",
        "theme_expectation",
        "viewport",
        "states",
        "primary_task",
        "capture_policy",
        "status"
      ],
      "properties": {
        "id": {"type": "string"},
        "url": {"type": "string", "format": "uri"},
        "category": {"enum": ["native-dark", "light-only", "dynamic-mixed"]},
        "theme_expectation": {"type": "string"},
        "viewport": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height", "device_scale_factor"],
          "properties": {
            "width": {"type": "integer", "minimum": 1},
            "height": {"type": "integer", "minimum": 1},
            "device_scale_factor": {"type": "number", "exclusiveMinimum": 0}
          }
        },
        "states": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "primary_task": {"type": "string"},
        "capture_policy": {"const": "manual-public-no-auth-no-crawl"},
        "status": {"const": "frozen-not-captured"}
      }
    }
  }
}
